@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find the dependencies that dolphin needs
find_dependency(OpenMP QUIET)
find_dependency(TIFF REQUIRED)
find_dependency(ITK REQUIRED)
find_dependency(JPEG QUIET)
find_dependency(ZLIB QUIET)
find_dependency(FFTW3f CONFIG QUIET)

# Include the targets file
include("${CMAKE_CURRENT_LIST_DIR}/dolphinTargets.cmake")

check_required_components(dolphin)
